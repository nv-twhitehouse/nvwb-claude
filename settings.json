{
  "model": "claude-opus-4-6",
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "denyWrite": ["$HOME/.claude/settings.json", "$HOME/.claude/skills/nvwb-claude", "$HOME/.claude/hooks", "$HOME/.claude.json", "$HOME/.claude/credentials.json"],
      "denyRead": ["~/.claude.json", "~/.claude/credentials.json"]
    },
    "autoAllowBashIfSandboxed": true
  },
  "permissions": {
    "additionalDirectories":["~/","/tmp/","/project/"], 
    "ask": ["Bash(git add *)", "Bash(git commit *)"],
    "deny": ["Bash(pip install *)", "Bash(pip3 install *)", "Bash(python -m pip install *)", "Bash(python3 -m pip install *)", "Bash(sudo *)",
  "Bash(docker *)", "Bash(podman *)"]
  },
  "hooks": {"PostToolUse": [ 
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "$HOME/.claude/hooks/block-secrets-in-bash.sh"
        }
      ]

    }
  ],
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command" : "python3 -c "import yaml; print('\n'.join(s['variable'] for s in yaml.safe_load(open('/project/.project/spec.yaml'))['execution']['secrets']))""
        }
      ]
    }
  ] 
  }  
}
