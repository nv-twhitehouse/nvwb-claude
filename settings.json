{
  "model": "claude-opus-4-6",
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "denyWrite": ["~/.claude/settings.json", "~/.claude/skills/nvwb-claude", "~/.claude/hooks", "~/.claude.json", "~/.claude/credentials.json"],
      "denyRead": ["~/.claude.json", "~/.claude/credentials.json"]
    },
    "autoAllowBashIfSandboxed": true
  },
  "permissions": {
    "additionalDirectories":["~/","/tmp/","/project/"], 
    "ask": ["Bash(git add *)", "Bash(git commit *)"],
    "deny": ["Bash(pip install *)", "Bash(pip3 install *)", "Bash(python -m pip install *)", "Bash(python3 -m pip install *)", "Bash(sudo *)",
  "Bash(docker *)", "Bash(podman *)"]
  },
  "hooks": {"SessionStart": [
    {
      "matcher": "startup",
      "hooks": [
        {
          "type": "command",
          "command": "$HOME/.claude/hooks/startup-claude.sh"
        }
      ]
    }
  ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          { 
            "type": "command",
            "command": "jq -c '{ts: (now | todate), event: \"permission_request\", tool: .tool_name, target: (.tool_input.file_path // .tool_input.command // .tool_input.pattern // \"n/a\")}' >> ~/claude_audit_logs/claude-audit.jsonl"
          }
        ]
    }
  ],
    "PostToolUse": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "jq -c '{ts: (now | todate), event: \"tool_used\", tool: .tool_name, target: (.tool_input.file_path // .tool_input.command // .tool_input.pattern // \"n/a\")}' >> ~/claude_audit_logs/claude-audit.jsonl"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command" : "$HOME/.claude/hooks/block-secrets-in-bash.sh"
        }
      ]
    }
  ] 
  }  
}
